# Pinned upstream versions. To move to newer versions later:
#   1. bump these values,
#   2. re-run scripts/build-deps.sh + the platform build script,
#   3. re-capture the AVIF container template if it changed
#      (see ImageContainers.java) and bump the pins in NativeImageCodec.java,
#   4. re-run the golden-image tests.
LIBWEBP_VERSION=1.6.0
LIBAVIF_VERSION=1.4.2
AOM_VERSION=3.14.1

LIBWEBP_URL=https://storage.googleapis.com/downloads.webmproject.org/releases/webp/libwebp-${LIBWEBP_VERSION}.tar.gz
LIBAVIF_URL=https://github.com/AOMediaCodec/libavif/archive/refs/tags/v${LIBAVIF_VERSION}.tar.gz
AOM_URL=https://storage.googleapis.com/aom-releases/libaom-${AOM_VERSION}.tar.gz

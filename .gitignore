# Build output - regenerated by build-jar.sh / obfuscate.sh / CI
dist/
build/
bin/
*.class

# Native build intermediates & outputs - CI/on-target rebuilds these
native/out/

# Upstream sources fetched by native/scripts/fetch-sources.sh (do NOT commit) —
# glob the CONTENTS so micro-ecc can be re-included (a parent dir can't be un-ignored).
native/third_party/*
# ...except micro-ecc: small, vendored, needed by CI for license verification.
!native/third_party/micro-ecc/
# but not its large per-arch asm blobs (unused — we force uECC_PLATFORM=0 generic C)
native/third_party/micro-ecc/asm_*.inc

# Bundled binaries are produced by CI per-OS; don't commit them
resources/native/*/libscimage.dylib
resources/native/*/libscimage.so
resources/native/*/scimage.dll
# keep the placeholder READMEs so the folder structure is versioned
!resources/native/*/README.txt

# ZKM logs
ZKM_log.txt
ZKM_TrimLog.txt
ZKM_WarningLog.txt
ZKM_LoadLog.txt
build/zkm/changeLog.txt

.DS_Store
